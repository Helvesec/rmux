{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rmux.io/schemas/release-candidate-manifest-v1.json",
  "title": "RMUX canonical release candidate manifest",
  "description": "Preparatory draft only. It MUST NOT authorize publication before the PR6 validators and workflows replace this draft contract.",
  "x-rmux-status": "draft-non-authoritative",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repository_id",
    "source_git_sha",
    "fast_run_id",
    "candidate_run_id",
    "candidate_run_attempt",
    "release_intent_id",
    "planned_release_ref",
    "release_kind",
    "release_version",
    "package_version",
    "is_prerelease",
    "fast_run_proof_sha256",
    "producer",
    "canonical_build_policy",
    "release_policy_sha256",
    "created_at",
    "expires_at",
    "jobs",
    "artifacts"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "repository_id": {"const": 1239918790},
    "source_git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "fast_run_id": {"type": "integer", "minimum": 1},
    "candidate_run_id": {"type": "integer", "minimum": 1},
    "candidate_run_attempt": {"const": 1},
    "release_intent_id": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{8,128}$"},
    "planned_release_ref": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-rc\\.[0-9]+)?$"},
    "release_kind": {"enum": ["shadow", "rc", "stable"]},
    "release_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-rc\\.[0-9]+)?$"},
    "package_version": {"type": "string", "pattern": "^[0-9A-Za-z][0-9A-Za-z.+~:-]{0,63}$"},
    "is_prerelease": {"type": "boolean"},
    "fast_run_proof_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_id", "workflow_path", "workflow_name", "event", "branch"],
      "properties": {
        "workflow_id": {"const": 277622540},
        "workflow_path": {"const": ".github/workflows/ci.yml"},
        "workflow_name": {"const": "CI"},
        "event": {"const": "workflow_dispatch"},
        "branch": {"const": "main"}
      }
    },
    "canonical_build_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fresh_target", "cargo_incremental", "cargo_locked", "object_cache_restored"],
      "properties": {
        "fresh_target": {"const": true},
        "cargo_incremental": {"const": false},
        "cargo_locked": {"const": true},
        "object_cache_restored": {"const": false}
      }
    },
    "release_policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "jobs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "conclusion"],
        "properties": {
          "id": {"type": "integer", "minimum": 1},
          "name": {"type": "string", "minLength": 1},
          "conclusion": {"enum": ["success", "skipped"]}
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "name", "archive_digest", "target_triple", "runner_image", "rust_toolchain", "rustc_vv_sha256", "files"],
        "properties": {
          "artifact_id": {"type": "integer", "minimum": 1},
          "name": {"type": "string", "minLength": 1},
          "archive_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "target_triple": {"type": "string", "pattern": "^[A-Za-z0-9_][A-Za-z0-9_.-]{2,63}$"},
          "runner_image": {
            "enum": ["macos-15", "macos-15-intel", "ubuntu-latest", "windows-latest"]
          },
          "rust_toolchain": {"type": "string", "minLength": 1, "maxLength": 128},
          "rustc_vv_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "files": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "size", "sha256"],
              "properties": {
                "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._+@=-]+(?:/[A-Za-z0-9._+@=-]+)*$"},
                "size": {"type": "integer", "minimum": 1},
                "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"release_kind": {"const": "stable"}}, "required": ["release_kind"]},
      "then": {
        "properties": {
          "planned_release_ref": {"pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "release_version": {"pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "is_prerelease": {"const": false}
        }
      }
    },
    {
      "if": {"properties": {"release_kind": {"const": "rc"}}, "required": ["release_kind"]},
      "then": {
        "properties": {
          "planned_release_ref": {"pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+-rc\\.[0-9]+$"},
          "release_version": {"pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+-rc\\.[0-9]+$"},
          "is_prerelease": {"const": true}
        }
      }
    },
    {
      "if": {"properties": {"planned_release_ref": {"pattern": "-rc\\.[0-9]+$"}}, "required": ["planned_release_ref"]},
      "then": {"properties": {"is_prerelease": {"const": true}}},
      "else": {"properties": {"is_prerelease": {"const": false}}}
    }
  ]
}
