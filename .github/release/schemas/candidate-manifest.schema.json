{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rmux.io/schemas/release-candidate-manifest-v1.json",
  "title": "RMUX sealed shadow release candidate manifest",
  "description": "Shadow evidence only. It MUST NOT authorize publication; PR8 cut-over remains a separate reviewed operation.",
  "x-rmux-status": "shadow-non-authoritative",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repository_id",
    "source_git_sha",
    "fast_run_id",
    "candidate_run_id",
    "candidate_run_attempt",
    "release_intent_id",
    "planned_release_ref",
    "release_kind",
    "release_version",
    "package_version",
    "is_prerelease",
    "producer",
    "proofs",
    "canonical_build_policy",
    "release_policy",
    "created_at",
    "expires_at",
    "jobs",
    "artifacts"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "repository_id": {"const": 1239918790},
    "source_git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "fast_run_id": {"type": "integer", "minimum": 1},
    "candidate_run_id": {"type": "integer", "minimum": 1},
    "candidate_run_attempt": {"const": 1},
    "release_intent_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]{8,128}$"
    },
    "planned_release_ref": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-rc\\.[0-9]+)?$"
    },
    "release_kind": {"enum": ["shadow", "rc", "stable"]},
    "release_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-rc\\.[0-9]+)?$"
    },
    "package_version": {
      "type": "string",
      "pattern": "^[0-9A-Za-z][0-9A-Za-z.+~:-]{0,63}$"
    },
    "is_prerelease": {"type": "boolean"},
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_id", "workflow_path", "workflow_name", "event", "branch"],
      "properties": {
        "workflow_id": {"const": 277622540},
        "workflow_path": {"const": ".github/workflows/ci.yml"},
        "workflow_name": {"const": "CI"},
        "event": {"const": "workflow_dispatch"},
        "branch": {"const": "main"}
      }
    },
    "proofs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fast_semantic_sha256",
        "fast_document_sha256",
        "candidate_semantic_sha256",
        "candidate_document_sha256",
        "intent_document_sha256",
        "policy_document_sha256",
        "canonical_metadata_document_sha256"
      ],
      "properties": {
        "fast_semantic_sha256": {"$ref": "#/$defs/sha256"},
        "fast_document_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_semantic_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_document_sha256": {"$ref": "#/$defs/sha256"},
        "intent_document_sha256": {"$ref": "#/$defs/sha256"},
        "policy_document_sha256": {"$ref": "#/$defs/sha256"},
        "canonical_metadata_document_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "canonical_build_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fresh_target",
        "cargo_incremental",
        "cargo_locked",
        "object_cache_restored",
        "publication_authority"
      ],
      "properties": {
        "fresh_target": {"const": true},
        "cargo_incremental": {"const": false},
        "cargo_locked": {"const": true},
        "object_cache_restored": {"const": false},
        "publication_authority": {"const": false}
      }
    },
    "release_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "contract_blob_oid", "record_count"],
      "properties": {
        "sha256": {"$ref": "#/$defs/sha256"},
        "contract_blob_oid": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "record_count": {"type": "integer", "minimum": 1}
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "jobs": {
      "type": "array",
      "minItems": 50,
      "maxItems": 50,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "conclusion"],
        "properties": {
          "id": {"type": "integer", "minimum": 1},
          "name": {"type": "string", "minLength": 1},
          "conclusion": {"enum": ["success", "skipped"]}
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "platform_key",
          "target_triple",
          "runner_image",
          "rust_toolchain",
          "assets",
          "provenance",
          "build_record_sha256",
          "binding_sha256",
          "attestation",
          "files"
        ],
        "properties": {
          "platform_key": {"$ref": "#/$defs/platform_key"},
          "target_triple": {
            "enum": [
              "aarch64-apple-darwin",
              "aarch64-unknown-linux-gnu",
              "x86_64-apple-darwin",
              "x86_64-pc-windows-msvc",
              "x86_64-unknown-linux-gnu"
            ]
          },
          "runner_image": {
            "enum": [
              "macos-15",
              "macos-15-intel",
              "ubuntu-22.04",
              "ubuntu-22.04-arm",
              "windows-latest"
            ]
          },
          "rust_toolchain": {"const": "1.96.1"},
          "assets": {
            "allOf": [
              {"$ref": "#/$defs/artifact_reference"},
              {"properties": {"role": {"const": "canonical-assets"}}}
            ]
          },
          "provenance": {
            "allOf": [
              {"$ref": "#/$defs/artifact_reference"},
              {"properties": {"role": {"const": "canonical-provenance"}}}
            ]
          },
          "build_record_sha256": {"$ref": "#/$defs/sha256"},
          "binding_sha256": {"$ref": "#/$defs/sha256"},
          "attestation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["attestation_id", "bundle_file", "bundle_sha256"],
            "properties": {
              "attestation_id": {"type": "string", "minLength": 1, "maxLength": 256},
              "bundle_file": {"const": "build-provenance.sigstore.json"},
              "bundle_sha256": {"$ref": "#/$defs/sha256"}
            }
          },
          "files": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "role", "size", "sha256"],
              "properties": {
                "path": {
                  "type": "string",
                  "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._+@=-]+(?:/[A-Za-z0-9._+@=-]+)*$"
                },
                "role": {"enum": ["archive", "checksums", "debian", "rpm"]},
                "size": {"type": "integer", "minimum": 1},
                "sha256": {"$ref": "#/$defs/sha256"}
              }
            }
          }
        },
        "allOf": [
          {
            "if": {"properties": {"target_triple": {"const": "x86_64-unknown-linux-gnu"}}, "required": ["target_triple"]},
            "then": {"properties": {"platform_key": {"const": "linux-x86_64"}, "runner_image": {"const": "ubuntu-22.04"}}}
          },
          {
            "if": {"properties": {"target_triple": {"const": "aarch64-unknown-linux-gnu"}}, "required": ["target_triple"]},
            "then": {"properties": {"platform_key": {"const": "linux-aarch64"}, "runner_image": {"const": "ubuntu-22.04-arm"}}}
          },
          {
            "if": {"properties": {"target_triple": {"const": "x86_64-apple-darwin"}}, "required": ["target_triple"]},
            "then": {"properties": {"platform_key": {"const": "macos-x86_64"}, "runner_image": {"const": "macos-15-intel"}}}
          },
          {
            "if": {"properties": {"target_triple": {"const": "aarch64-apple-darwin"}}, "required": ["target_triple"]},
            "then": {"properties": {"platform_key": {"const": "macos-aarch64"}, "runner_image": {"const": "macos-15"}}}
          },
          {
            "if": {"properties": {"target_triple": {"const": "x86_64-pc-windows-msvc"}}, "required": ["target_triple"]},
            "then": {"properties": {"platform_key": {"const": "windows-x86_64"}, "runner_image": {"const": "windows-latest"}}}
          }
        ]
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "platform_key": {
      "enum": [
        "linux-aarch64",
        "linux-x86_64",
        "macos-aarch64",
        "macos-x86_64",
        "windows-x86_64"
      ]
    },
    "artifact_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "platform_key",
        "artifact_id",
        "name",
        "archive_digest",
        "size_in_bytes"
      ],
      "properties": {
        "role": {"enum": ["canonical-assets", "canonical-provenance"]},
        "platform_key": {"$ref": "#/$defs/platform_key"},
        "artifact_id": {"type": "integer", "minimum": 1},
        "name": {
          "type": "string",
          "pattern": "^rmux-canonical-(?:provenance-)?[A-Za-z0-9._-]+-[0-9a-f]{40}$"
        },
        "archive_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "size_in_bytes": {"type": "integer", "minimum": 1}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"release_kind": {"const": "stable"}}, "required": ["release_kind"]},
      "then": {
        "properties": {
          "planned_release_ref": {"pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "release_version": {"pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "is_prerelease": {"const": false}
        }
      }
    },
    {
      "if": {"properties": {"release_kind": {"const": "rc"}}, "required": ["release_kind"]},
      "then": {
        "properties": {
          "planned_release_ref": {"pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+-rc\\.[0-9]+$"},
          "release_version": {"pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+-rc\\.[0-9]+$"},
          "is_prerelease": {"const": true}
        }
      }
    },
    {
      "if": {"properties": {"planned_release_ref": {"pattern": "-rc\\.[0-9]+$"}}, "required": ["planned_release_ref"]},
      "then": {"properties": {"is_prerelease": {"const": true}}},
      "else": {"properties": {"is_prerelease": {"const": false}}}
    }
  ]
}
