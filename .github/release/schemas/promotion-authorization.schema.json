{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rmux.io/schemas/release-promotion-authorization-v1.json",
  "title": "RMUX release promotion authorization envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "predicate_type",
    "repository_id",
    "source_git_sha",
    "release_ref",
    "release_intent_id",
    "candidate_run_id",
    "candidate_manifest_artifact_id",
    "candidate_manifest_artifact_digest",
    "candidate_manifest_sha256",
    "release_policy_sha256",
    "authorization_run_id",
    "authorization_run_attempt",
    "authorization_attestation_id",
    "authorization_bundle_artifact_id",
    "authorization_bundle_artifact_digest",
    "sha256sums_sha256"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "predicate_type": {"const": "https://rmux.io/attestations/release-authorization/v1"},
    "repository_id": {"const": 1239918790},
    "source_git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "release_ref": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-rc\\.[0-9]+)?$"},
    "release_intent_id": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{8,128}$"},
    "candidate_run_id": {"type": "integer", "minimum": 1},
    "candidate_manifest_artifact_id": {"type": "integer", "minimum": 1},
    "candidate_manifest_artifact_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "candidate_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "release_policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "authorization_run_id": {"type": "integer", "minimum": 1},
    "authorization_run_attempt": {"const": 1},
    "authorization_attestation_id": {"type": "string", "minLength": 1},
    "authorization_bundle_artifact_id": {"type": "integer", "minimum": 1},
    "authorization_bundle_artifact_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "sha256sums_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
