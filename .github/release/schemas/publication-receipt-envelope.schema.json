{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rmux.io/schemas/release-publication-receipt-envelope-v1.json",
  "title": "RMUX publication receipt post-upload envelope",
  "description": "Receipt binding whose downstream authority must match its predicate and the tracked atomic release ledger.",
  "x-rmux-status": "atomic-authority-bound",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "envelope_type",
    "status",
    "downstream_authority",
    "repository_id",
    "source_git_sha",
    "release_id",
    "release_ref",
    "release_intent_id",
    "receipt",
    "predicate_sha256",
    "attestation",
    "receipt_bundle",
    "created_at"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "envelope_type": {"const": "https://rmux.io/envelopes/release-publication-receipt/v1"},
    "status": {"enum": ["disarmed-non-authoritative", "downstream-authorized"]},
    "downstream_authority": {"type": "boolean"},
    "repository_id": {"const": 1239918790},
    "source_git_sha": {"$ref": "#/$defs/sha40"},
    "release_id": {"type": "integer", "minimum": 1},
    "release_ref": {"$ref": "#/$defs/release_ref"},
    "release_intent_id": {"$ref": "#/$defs/intent"},
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "run_attempt", "workflow_id", "workflow_path"],
      "properties": {
        "run_id": {"type": "integer", "minimum": 1},
        "run_attempt": {"const": 1},
        "workflow_id": {"type": "integer", "minimum": 1},
        "workflow_path": {"const": ".github/workflows/release-receipt.yml"}
      }
    },
    "predicate_sha256": {"$ref": "#/$defs/sha256"},
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attestation_id", "bundle_file", "bundle_sha256"],
      "properties": {
        "attestation_id": {"type": "string", "minLength": 1, "maxLength": 256},
        "bundle_file": {"const": "publication-receipt.sigstore.json"},
        "bundle_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "receipt_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "name", "archive_digest", "size_in_bytes"],
      "properties": {
        "artifact_id": {"type": "integer", "minimum": 1},
        "name": {"type": "string", "pattern": "^rmux-publication-receipt-[0-9a-f]{40}-[1-9][0-9]*$"},
        "archive_digest": {"$ref": "#/$defs/digest"},
        "size_in_bytes": {"type": "integer", "minimum": 1}
      }
    },
    "created_at": {"type": "string", "format": "date-time"}
  },
  "oneOf": [
    {
      "properties": {
        "status": {"const": "disarmed-non-authoritative"},
        "downstream_authority": {"const": false}
      }
    },
    {
      "properties": {
        "status": {"const": "downstream-authorized"},
        "downstream_authority": {"const": true}
      }
    }
  ],
  "$defs": {
    "sha40": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "intent": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{8,128}$"},
    "release_ref": {"type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-rc\\.[0-9]+)?$"}
  }
}
